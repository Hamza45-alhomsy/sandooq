generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int        @id @default(autoincrement())
  uid               String     @unique
  email             String     @unique
  fullName          String
  phone             String?
  roleId            Int
  isActive          Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  auditLogs         AuditLog[]
  uploadedDocuments Document[]
  approvedOrders    Order[]    @relation("ApprovedOrders")
  executedOrders    Order[]    @relation("ExecutedOrders")
  orders            Order[]
  role              Role       @relation(fields: [roleId], references: [id], onDelete: NoAction)

  @@index([roleId], map: "users_roleId_fkey")
  @@map("users")
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  permissions Permission[]
  users       User[]

  @@map("roles")
}

model Permission {
  id        Int      @id @default(autoincrement())
  roleId    Int
  resource  String
  action    String
  createdAt DateTime @default(now())
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, resource, action])
  @@map("permissions")
}

model Fund {
  id             Int           @id @default(autoincrement())
  name           String        @default("Main Fund")
  currentBalance Float         @default(0)
  currency       String        @default("SYP")
  description    String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  transactions   Transaction[]

  @@map("funds")
}

model Order {
  id           Int          @id @default(autoincrement())
  orderNumber  String       @unique
  type         String
  status       String       @default("pending")
  totalAmount  Float
  description  String?
  userId       Int
  approvedById Int?
  executedById Int?
  executedAt   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  documents    Document[]
  items        OrderItem[]
  approvedBy   User?        @relation("ApprovedOrders", fields: [approvedById], references: [id])
  executedBy   User?        @relation("ExecutedOrders", fields: [executedById], references: [id])
  user         User         @relation(fields: [userId], references: [id], onDelete: NoAction)
  transaction  Transaction?

  @@index([status, createdAt])
  @@index([userId, createdAt])
  @@index([orderNumber])
  @@index([approvedById], map: "orders_approvedById_fkey")
  @@index([executedById], map: "orders_executedById_fkey")
  @@map("orders")
}

model OrderItem {
  id          Int       @id @default(autoincrement())
  orderId     Int
  description String
  quantity    Int       @default(1)
  unitPrice   Float
  totalPrice  Float
  categoryId  Int?
  createdAt   DateTime  @default(now())
  category    Category? @relation(fields: [categoryId], references: [id])
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([categoryId], map: "order_items_categoryId_fkey")
  @@index([orderId], map: "order_items_orderId_fkey")
  @@map("order_items")
}

model Category {
  id          Int         @id @default(autoincrement())
  name        String      @unique
  type        String
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  items       OrderItem[]

  @@map("categories")
}

model Transaction {
  id            Int      @id @default(autoincrement())
  orderId       Int      @unique
  fundId        Int
  amount        Float
  balanceBefore Float
  balanceAfter  Float
  description   String?
  createdAt     DateTime @default(now())
  fund          Fund     @relation(fields: [fundId], references: [id], onDelete: NoAction)
  order         Order    @relation(fields: [orderId], references: [id], onDelete: NoAction)

  @@index([createdAt])
  @@index([fundId, createdAt])
  @@map("transactions")
}

model Document {
  id           Int      @id @default(autoincrement())
  orderId      Int
  fileName     String
  fileUrl      String
  fileSize     Int?
  mimeType     String?
  uploadedById Int
  description  String?
  createdAt    DateTime @default(now())
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  uploadedBy   User     @relation(fields: [uploadedById], references: [id], onDelete: NoAction)

  @@index([orderId, createdAt])
  @@index([uploadedById], map: "documents_uploadedById_fkey")
  @@map("documents")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int
  action     String
  entityType String
  entityId   Int
  details    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: NoAction)

  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model Setting {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String
  description String?
  group       String
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("settings")
}
